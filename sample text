 pipeline {
        agent any
        tools {
            maven 'M3' // Replace 'M3' with your configured Maven tool name
            jdk 'JDK8' // Replace 'JDK8' with your configured JDK tool name
        }
        stages {
            stage('Build') {
                steps {
                    withMaven(maven: 'M3') {
                        sh 'mvn clean install' // Execute Maven goals
                    }
                }
            }
        }
    }
