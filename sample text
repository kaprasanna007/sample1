pipeline {
  agent any

  options {
    timestamps()
    ansiColor('xterm')
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 30, unit: 'MINUTES')
  }

  tools {
    jdk 'jdk-17'         // Manage Jenkins > Tools > JDK installations (name: jdk-17)
    maven 'maven-3.9'    // Manage Jenkins > Tools > Maven installations (name: maven-3.9)
  }

  environment {
    APP_NAME = 'myapp'
    DOCKER_REGISTRY = 'registry.hub.docker.com'
    DOCKER_IMAGE = "your-docker-username/${APP_NAME}"
    DOCKER_TAG = "${env.BUILD_NUMBER}"
    // Optional coverage file if you use jacoco-maven-plugin
    JACOCO_XML = 'target/site/jacoco/jacoco.xml'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        // Or specify explicitly:
        // git branch: 'main', url: 'https://github.com/your/repo.git', credentialsId: 'git-cred'
      }
    }

    stage('Build & Unit Tests') {
      steps {
        sh 'mvn -B -e -U clean test'
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
          // If you have Jacoco configured in pom.xml, Jenkins can publish coverage with plugins:
          // jacoco execPattern: 'target/jacoco.exec', classPattern: 'target/classes', sourcePattern: 'src/main/java'
          // Or with the generic Coverage plugin using JACOCO_XML
          recordCoverage tools: [[parser: 'JACOCO', pattern: "${JACOCO_XML}"]], sourceCodeRetention: 'EVERY_BUILD', failIfCoverageDecreasedInChange: false
        }
      }
    }

    stage('Package') {
      steps {
        sh 'mvn -B package -DskipTests=false'
      }
      post {
        success {
          archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
      } }
    }

    stage('Docker Build & Push') {
      when {
        expression { fileExists('Dockerfile') }
      }
      environment {
        // Docker registry creds: create in Jenkins as Username/Password credentials with ID 'docker-hub'
        DOCKERHUB_CREDS = credentials('docker-hub')
      }
      steps {
        sh """
          echo "${DOCKERHUB_CREDS_PSW}" | docker login -u "${DOCKERHUB_CREDS_USR}" --password-stdin
          docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} -t ${DOCKER_IMAGE}:latest .
          docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
          docker push ${DOCKER_IMAGE}:latest
        """
      }
      post {
        always {
          sh 'docker logout || true'
        }
      }
    }

    stage('Deploy to Server') {
      // Two options: (A) deploy Docker container, (B) copy JAR to server & restart service.
      // Enable the one you use by leaving it uncommented.
      environment {
        // Create SSH credentials in Jenkins (Kind: SSH Username with private key) with ID 'prod-ssh'
        // and ensure the target host has that pubkey authorized.
      }
      steps {
        script {
          // --- Option A: Docker deploy via SSH ---
          sshagent(credentials: ['prod-ssh']) {
            sh """
              ssh -o StrictHostKeyChecking=no user@your-server '
                set -e
                echo "Pulling image ${DOCKER_IMAGE}:${DOCKER_TAG}..."
                docker pull ${DOCKER_IMAGE}:${DOCKER_TAG}
                docker rm -f ${APP_NAME} || true
                docker run -d --name ${APP_NAME} -p 8080:8080 ${DOCKER_IMAGE}:${DOCKER_TAG}
              '
            """
          }

          // --- Option B: Copy JAR and restart (commented by default) ---
          // sshagent(credentials: ['prod-ssh']) {
          //   sh '''
          //     JAR_FILE=$(ls target/*.jar | head -n1)
          //     scp -o StrictHostKeyChecking=no "$JAR_FILE" user@your-server:/opt/myapp/app.jar
          //     ssh -o StrictHostKeyChecking=no user@your-server '
          //       sudo systemctl restart myapp.service
          //       systemctl --no-pager status myapp.service || true
          //     '
          //   '''
          // }
        }
      }
    }
  }

  post {
    success {
      echo "✅ Build #${env.BUILD_NUMBER} successful: ${env.JOB_NAME}"
    }
    failure {
      echo "❌ Build failed. Check stages and logs."
    }
    always {
      cleanWs deleteDirs: true
    }
  }
}
